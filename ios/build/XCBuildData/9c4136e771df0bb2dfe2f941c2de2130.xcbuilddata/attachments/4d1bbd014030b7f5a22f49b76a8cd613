#!/bin/sh
FLAVOR=$(echo "$CONFIGURATION" | sed 's/Debug-//' | sed 's/Release-//' | sed 's/Profile-//')
SRC="${PROJECT_DIR}/config/${FLAVOR}/GoogleService-Info.plist"
DST="${BUILT_PRODUCTS_DIR}/${PRODUCT_NAME}.app/GoogleService-Info.plist"
if [ -f "$SRC" ]; then
  cp "$SRC" "$DST"
else
  echo "warning: GoogleService-Info.plist not found at $SRC"
fi

